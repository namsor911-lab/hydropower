# Database
DATABASE_URL=./database/namsor.db
DATABASE_ENCRYPTION_KEY=your-secret-key-here

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:8000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Email (optional for future notifications)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
